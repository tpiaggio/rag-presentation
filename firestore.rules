rules_version = '2';

// All client access denied. Admin SDK from server routes bypasses these rules.
// If a fork ever needs read-only client access to a specific collection,
// add a narrowly-scoped match block above the catch-all.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
