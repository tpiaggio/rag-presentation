# Gemini
GOOGLE_GENERATIVE_AI_API_KEY=

# Firebase Admin (path to service-account JSON outside this repo; local dev only)
# On App Hosting / Cloud Run this is unset and Admin SDK uses ADC automatically.
FIREBASE_ADMIN_SA_PATH=/Users/tomaspiaggio/.config/centinel-rag-demo/sa.json
FIREBASE_PROJECT_ID=centinel-rag-demo
FIREBASE_STORAGE_BUCKET=centinel-rag-demo.firebasestorage.app

# Access gate (optional)
# Leave empty for local dev — every request passes through ungated.
# Set to a non-empty string on App Hosting to require visitors to enter it at /unlock.
# Rotating this value invalidates all existing cookies.
ACCESS_PASSCODE=
